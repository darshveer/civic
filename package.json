    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.2.3",
    "exifreader": "^4.23.7",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
