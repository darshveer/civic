# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps JS SDK capabilities.
GOOGLE_MAPS_PLATFORM_KEY="MY_GOOGLE_MAPS_PLATFORM_KEY"


# --- AI fallback cascade (all optional, tried in this order) ---
# Tier 2: a lighter Gemini model used if the primary model is overloaded.
GEMINI_FALLBACK_MODEL="gemini-2.5-flash-lite"
# Tier 3: z.ai native (GLM). Supports function calling, so tool-using agents
# keep working on this tier. Free model: glm-4.5-flash. https://z.ai/
ZAI_API_KEY=""
ZAI_MODEL="glm-4.5-flash"
# Tier 4: OpenRouter. Pick a free, tool-capable model (function calling works).
# NB: GLM-4.5-Air is no longer free on OpenRouter; this default is. Override to
# the paid "z-ai/glm-4.5-air" if you want GLM here. https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemma-4-31b-it:free"
# Tier 5: Groq (text-only Llama — ignores tools). https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Email OTP for registration (free, via SMTP / nodemailer) ---
# Easiest free option: a Gmail account with 2FA on + an "App Password"
# (https://myaccount.google.com/apppasswords). Sends to any recipient, no domain.
# Without these, OTP codes are shown on screen in local dev (required in prod).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.address@gmail.com"
SMTP_PASS="your_16_char_app_password"
OTP_FROM_EMAIL="CIVIC <your.address@gmail.com>"

# Custom Firebase credentials (Optional).
# If you want to use your own Firebase project instead of the default AI Studio one,
# provide your Firebase config values here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# --- Admin / staff provisioning gate ---------------------------------------
# Staff are NOT self-service: an administrator provisions them in the in-app
# Admin Panel. Access to that panel is gated by all three values below, checked
# server-side. (TOTP 2FA is done with Node crypto — no Firebase MFA / billing.)
#
# 1) ADMIN_EMAILS — comma-separated admin email allowlist. Also add the SAME
#    email(s) to adminEmails() in firestore.rules and deploy the rules (that's
#    what actually authorises writing the staff registry). Create your admin
#    email/password account FIRST so nobody else can register it.
ADMIN_EMAILS="you@yourdomain.com"
# 2) ADMIN_SECRET_CODE — the "key" you type after logging in (only you know it).
ADMIN_SECRET_CODE="change-me-to-a-long-random-string"
# 3) ADMIN_TOTP_SECRET — base32 secret for your authenticator app (Google
#    Authenticator / Authy). Leave blank, open the Admin Panel → "Set up the
#    authenticator" to generate one, add it to your app, then paste it here and
#    restart. Compulsory for admin login.
ADMIN_TOTP_SECRET=""

# --- Optional per-staff 2FA (authenticator app, self-service from profile) ---
# A server-only key used to AES-encrypt each staff member's TOTP secret before
# it's stored in their (owner-only) Firestore doc — so reading the DB never
# reveals the secret, and verification must go through the server. Set ANY long
# random string to enable the "Security & 2FA" option for staff. Leave blank to
# disable staff 2FA entirely. (Changing it later invalidates existing staff 2FA.)
STAFF_2FA_KEY=""